# ============================================================
# CultivaClub - Monólito - Variáveis de Ambiente (exemplo)
# ============================================================
# Copie este arquivo como `.env` localmente (ou configure-as no
# painel do seu provedor de deploy: Railway / Render / Fly.io).
# NÃO commite valores reais — este arquivo é só referência.
# ============================================================

# --- Servidor -----------------------------------------------
SERVER_PORT=8080

# --- Database USUÁRIOS (Supabase - database "cultivaclub_usuarios") ---
# Formato JDBC do Supabase (use o "Connection pooling" > "Session" do painel):
#   jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USUARIOS_URL=jdbc:postgresql://<HOST>:5432/<DATABASE_USUARIOS>?sslmode=require
DB_USUARIOS_USERNAME=postgres.<PROJECT_REF>
DB_USUARIOS_PASSWORD=<SENHA_POOLER>
DB_USUARIOS_POOL_MAX=5
DB_USUARIOS_POOL_MIN=1

# --- Database OBJETOS (Supabase - database "cultivaclub_objetos") ----
DB_OBJETOS_URL=jdbc:postgresql://<HOST>:5432/<DATABASE_OBJETOS>?sslmode=require
DB_OBJETOS_USERNAME=postgres.<PROJECT_REF>
DB_OBJETOS_PASSWORD=<SENHA_POOLER>
DB_OBJETOS_POOL_MAX=5
DB_OBJETOS_POOL_MIN=1

# --- JPA / Hibernate ----------------------------------------
# validate  -> (recomendado em prod) só confere o schema
# none      -> desliga qualquer checagem/geração
# update    -> (APENAS DEV) Hibernate ajusta o schema sozinho
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# --- Autenticação JWT ---------------------------------------
# 32+ caracteres aleatórios. Gere com:
#   openssl rand -base64 48
JWT_SECRET=<TROQUE_POR_UM_SEGREDO_LONGO>
JWT_EXPIRATION=86400000

# --- Admin reservado (opcional) -----------------------------
# Se preenchido, a aplicação inicializa/valida esta conta como role=ADMIN
ADMIN_LOGIN=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- CORS ---------------------------------------------------
# Lista separada por vírgula (sem espaços extras). Inclua TODOS os
# domínios do frontend (local + produção).
FRONTEND_URL=http://localhost:3000,https://cultivaclub.vercel.app

# --- Logs ---------------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
